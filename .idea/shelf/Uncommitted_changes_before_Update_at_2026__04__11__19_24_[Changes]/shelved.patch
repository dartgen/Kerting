+
+// --- ÁLLAPOTOK ---
+const activeFilter = ref<'ongoing' | 'archived' | 'invited'>('ongoing');
+const selectedProjectId = ref<number | null>(null);
+const isLoading = ref(true);
+
+const showProjectModal = ref(false);
+const showTaskCreateModal = ref(false);
